% ══════════════════════════════════════════════════════════════════════════════════
% 参考文献模板 (BibTeX 格式)
% ══════════════════════════════════════════════════════════════════════════════════
% 
% 【使用说明】
% 1. 在此文件中添加参考文献条目
% 2. 在正文中使用 \cite{引用标签} 进行引用
% 3. 在文档末尾使用 \printbibliography 生成参考文献列表
%
% 【常用文献类型】
% @article   - 期刊论文
% @book      - 书籍
% @inproceedings - 会议论文
% @thesis    - 学位论文
% @online    - 网络资源
%
% ══════════════════════════════════════════════════════════════════════════════════


% ------------------------------------------------------------------------------
% 期刊论文示例 (Journal Article)
% ------------------------------------------------------------------------------
@article{article_example,
    author = {【作者姓名】},
    title = {【论文标题】},
    journal = {【期刊名称】},
    volume = {1},
    number = {1},
    pages = {1--10},
    year = {2024},
    publisher = {【出版社】}
}


% ------------------------------------------------------------------------------
% 书籍示例 (Book)
% ------------------------------------------------------------------------------
@book{book_example,
    author = {【作者姓名】},
    title = {【书籍标题】},
    year = {2024},
    publisher = {【出版社】},
    address = {【出版地】}
}


% ------------------------------------------------------------------------------
% 会议论文示例 (Conference Paper)
% ------------------------------------------------------------------------------
@inproceedings{conference_example,
    author = {【作者姓名】},
    title = {【论文标题】},
    booktitle = {【会议名称】},
    year = {2024},
    pages = {1--10},
    organization = {【组织机构】}
}


% ------------------------------------------------------------------------------
% 学位论文/报告示例 (Thesis/Report)
% ------------------------------------------------------------------------------
@thesis{thesis_example,
    author = {【作者姓名】},
    title = {【论文/报告标题】},
    type = {硕士学位论文},
    school = {【学校/机构名称】},
    year = {2024},
    address = {【地址】}
}


% ------------------------------------------------------------------------------
% 网络资源示例 (Online Resource)
% ------------------------------------------------------------------------------
@online{online_example,
    author = {【作者/机构】},
    title = {【网页标题】},
    url = {https://example.com},
    urldate = {2024-01-01},
    year = {2024}
}